MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority
JWT_SECRET=replace_with_strong_secret
PORT=5000

# Gmail SMTP (use Gmail App Password, not your regular password)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your_gmail_app_password

# Super Admin (auto-created on first startup)
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=your_admin_password

# Google Gemini AI (get free key at https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key

# Frontend URL for CORS (set in production)
FRONTEND_URL=http://localhost:3000
